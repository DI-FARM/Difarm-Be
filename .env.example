# Copy this file to .env and fill in your values.
# Required for the app to run.

# Server
PORT=4000

# Database (PostgreSQL). Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/difarm

# Frontend URL (for CORS and password-reset links). Must match where the React app runs.
FRONTEND_UrL=http://localhost:3000

# JWT (use long random strings in production)
JWT_SECRET=your-jwt-secret-key-change-in-production
EXPIRE_TIME=7d
JWT_VERIF_SECRET=your-email-verification-secret
EXPIRE_VERIF_TIME=24h

# Email (Gmail). For password reset and notifications.
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL=your-email@gmail.com
